* {
  font-family: "JetBrainsMono Nerd Font Mono";
  font-size: 13px;
  border-radius: 0;
}

window#waybar {
  background-color: $base00;
  color: $base05;
}

#workspaces button {
  border: none;
  box-shadow: none;
  padding: 0 8px;
  color: $base05;
}

#workspaces button.active {
  color: $base0B;
}

#clock, #battery, #network {
  padding: 0 12px;
}

#network {
  font-size: 18px;
  padding: 0 12px 0 22px;
}
